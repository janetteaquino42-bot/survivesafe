// Forum Routes
use App\Http\Controllers\ForumController;

// Forum reading routes - Available to all authenticated users (including pending)
Route::middleware(['auth'])->group(function () {
    Route::get('/forum', [ForumController::class, 'index'])->name('forum.index');
    Route::get('/forum/posts/{post}', [ForumController::class, 'show'])->name('forum.posts.show');
});

// Forum interaction routes - Require verified users only
Route::middleware(['auth', 'verified'])->group(function () {
    Route::post('/forum/posts', [ForumController::class, 'store'])->name('forum.posts.store');
    Route::put('/forum/posts/{post}', [ForumController::class, 'update'])->name('forum.posts.update');
    Route::delete('/forum/posts/{post}', [ForumController::class, 'destroy'])->name('forum.posts.destroy');
    Route::post('/forum/posts/{post}/like', [ForumController::class, 'like'])->name('forum.posts.like');
    Route::post('/forum/posts/{post}/comments', [ForumController::class, 'storeComment'])->name('forum.comments.store');
    Route::put('/forum/comments/{comment}', [ForumController::class, 'updateComment'])->name('forum.comments.update');
    Route::delete('/forum/comments/{comment}', [ForumController::class, 'destroyComment'])->name('forum.comments.destroy');
});

