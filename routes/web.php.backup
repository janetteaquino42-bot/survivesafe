Route::middleware(['auth', 'verified', 'admin'])->prefix('admin')->name('admin.')->group(function () {
    // Dashboard
    Route::get('/dashboard', [AdminController::class, 'dashboard'])->name('dashboard');

    // Seller Applications
    Route::get('/sellers/applications', [AdminController::class, 'sellerApplications'])->name('sellers.applications');
    Route::post('/sellers/{id}/approve', [AdminController::class, 'approveSeller'])->name('sellers.approve');
    Route::post('/sellers/{id}/decline', [AdminController::class, 'declineSeller'])->name('sellers.decline');

    // Artworks Management
    Route::get('/artworks', [AdminController::class, 'allArtworks'])->name('artworks.index');
    Route::get('/artworks/pending', [AdminController::class, 'pendingArtworks'])->name('artworks.pending');
    Route::post('/artworks', [AdminController::class, 'storeArtwork'])->name('artworks.store');
    Route::patch('/artworks/{id}', [AdminController::class, 'updateArtwork'])->name('artworks.update');
    Route::delete('/artworks/{id}', [AdminController::class, 'destroyArtwork'])->name('artworks.destroy');
    Route::post('/artworks/{id}/approve', [AdminController::class, 'approveArtwork'])->name('artworks.approve');
    Route::post('/artworks/{id}/decline', [AdminController::class, 'declineArtwork'])->name('artworks.decline');

    // Materials Management
    Route::get('/materials', [AdminController::class, 'allMaterials'])->name('materials.index');
    Route::get('/materials/pending', [AdminController::class, 'pendingMaterials'])->name('materials.pending');
    Route::post('/materials', [AdminController::class, 'storeMaterial'])->name('materials.store');
    Route::patch('/materials/{id}', [AdminController::class, 'updateMaterial'])->name('materials.update');
    Route::delete('/materials/{id}', [AdminController::class, 'destroyMaterial'])->name('materials.destroy');
    Route::post('/materials/{id}/approve', [AdminController::class, 'approveMaterial'])->name('materials.approve');
    Route::post('/materials/{id}/decline', [AdminController::class, 'declineMaterial'])->name('materials.decline');

    // Categories Management
    Route::get('/categories/all', [AdminController::class, 'artworkCategories'])->name('categories.index');
    Route::get('/categories/{id}/details', [AdminController::class, 'getCategoryDetails'])->name('categories.details');
    Route::post('/categories/artworks', [AdminController::class, 'storeArtworkCategory'])->name('categories.artworks.store');
    Route::patch('/categories/artworks/{id}', [AdminController::class, 'updateArtworkCategory'])->name('categories.artworks.update');
    Route::delete('/categories/artworks/{id}', [AdminController::class, 'deleteArtworkCategory'])->name('categories.artworks.delete');

    // Orders Management
    Route::get('/orders', [AdminController::class, 'allOrders'])->name('orders.index');

    // Exhibits Management
    Route::get('/exhibits/all', [AdminController::class, 'allExhibits'])->name('exhibits.all');
    Route::get('/exhibits/pending', [AdminController::class, 'pendingExhibits'])->name('exhibits.pending');
    Route::post('/exhibits', [AdminController::class, 'storeExhibit'])->name('exhibits.store');
    Route::patch('/exhibits/{id}', [AdminController::class, 'updateExhibit'])->name('exhibits.update');
    Route::delete('/exhibits/{id}', [AdminController::class, 'destroyExhibit'])->name('exhibits.destroy');
    Route::post('/exhibits/{id}/approve', [AdminController::class, 'approveExhibit'])->name('exhibits.approve');
    Route::post('/exhibits/{id}/decline', [AdminController::class, 'declineExhibit'])->name('exhibits.decline');

    // Users Management
