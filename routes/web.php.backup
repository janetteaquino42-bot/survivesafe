    Route::delete('/artworks/{id}', [SellerController::class, 'destroyArtwork'])->name('artworks.destroy');

    // Materials Management
    Route::get('/materials', [SellerController::class, 'materials'])->name('materials.index');
    Route::post('/materials', [SellerController::class, 'storeMaterial'])->name('materials.store');
    Route::patch('/materials/{id}', [SellerController::class, 'updateMaterial'])->name('materials.update');
    Route::delete('/materials/{id}', [SellerController::class, 'destroyMaterial'])->name('materials.destroy');

    // Exhibits Management
    Route::get('/exhibits', [SellerController::class, 'exhibits'])->name('exhibits.index');
    Route::delete('/exhibits/{id}', [SellerController::class, 'destroyExhibit'])->name('exhibits.destroy');
    Route::post('/exhibits', [SellerController::class, 'storeExhibit'])->name('exhibits.store');
