    Route::delete('/content/about/gallery/remove', [AdminController::class, 'removeAboutGalleryImage'])->name('content.about.gallery.remove');
    Route::post('/content/about/features', [AdminController::class, 'updateAboutFeatures'])->name('content.about.features');
