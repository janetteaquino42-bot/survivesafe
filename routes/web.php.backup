// Temporary manual verification route for testing
Route::get('/manual-verify/{userId}', function ($userId) {
    $user = \App\Models\User::find($userId);
    
    if (!$user) {
        return redirect()->route('home')->with('error', 'User not found.');
    }
    
    if ($user->hasVerifiedEmail()) {
        return redirect()->route('home')->with('message', 'Email already verified.');
    }
    
    // Manually verify the user
    $user->markEmailAsVerified();
    $user->upgradeToVerifiedUser();
    
    return redirect()->route('home')->with('message', 'Email verified successfully! You can now make transactions.');
})->middleware('auth')->name('manual.verify');

